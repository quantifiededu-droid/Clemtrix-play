generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  skillLevel    SkillLevel @default(BEGINNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  progress      Progress[]
  attempts      QuizAttempt[]
}

model Lesson {
  id               String    @id @default(cuid())
  title            String
  description      String
  skillLevel       SkillLevel
  order            Int
  content          Json
  estimatedMinutes Int
  progress         Progress[]
  questions        QuizQuestion[]
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  score       Int?
  user        User     @relation(fields: [userId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model QuizQuestion {
  id            String   @id @default(cuid())
  lessonId      String
  question      String
  options       Json
  correctAnswer Int
  explanation   String
  lesson        Lesson   @relation(fields: [lessonId], references: [id])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  answers        Json
  score          Int
  totalQuestions Int
  passedAt       DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}
